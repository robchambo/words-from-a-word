app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Level generator — computed vocabulary caches (regenerated by calibrate scripts)
tools/level_generator/vocab_cache_ru.json
tools/level_generator/vocab_cache_en.json
